--- /dev/null
+++ b/gear_sonic/data/vla_token_injector.py
@@ -0,0 +1,176 @@
+"""VLA token injector — eval-callback that DRIVES SONIC with GR00T's predicted tokens.
+
+Counterpart to vla_token_recorder: instead of READING the actor's token at decode, it
+REPLACES ``decode_input_dict["token_flattened"]`` with a precomputed GR00T motion_token
+trajectory (from scripts/gr00t_dump_pred_tokens.py). SONIC's WBC then decodes GR00T's
+tokens into balanced joints — so the Isaac viewer shows *what the current GR00T checkpoint
+actually drives* (prompt -> GR00T -> token -> SONIC -> G1), with no C++/ZMQ.
+
+We trained GR00T on the QUANTIZED token (action.motion_token == the post-FSQ token the
+recorder captured), so injecting at the post-quantization ``token_flattened`` input of
+``decode`` is the matching level (not pre_quantization_replace).
+
+The reference motion still feeds the env's observations/command (so the green ref skeleton
+shows the TARGET); only the executed action follows GR00T's token. Press V to see ref vs
+actual, F for free camera.
+"""
+
+from __future__ import annotations
+
+import numpy as np
+
+try:
+    from loguru import logger
+except Exception:  # pragma: no cover
+    import logging
+
+    logger = logging.getLogger(__name__)
+
+
+class VlaTokenInjector:
+    """Eval-callback: feed a saved GR00T motion_token trajectory into SONIC's decoder."""
+
+    model = None  # injected by the eval loop
+
+    def __init__(self, token_npz: str, decoder_name: str = "g1_dyn", loop: bool = True,
+                 tint_env0_green: bool = False):
+        # token_npz: one path, or comma-separated paths (one per env, e.g. GT,predicted for
+        # side-by-side teacher-vs-student). env i uses list[i % len].
+        # tint_env0_green: paint env_0's robot translucent green (the "teacher" reference),
+        # the conventional motion-tracking viz when comparing reference vs policy.
+        self.token_npz = token_npz
+        self.decoder_name = decoder_name
+        self.loop = loop
+        self.tint_env0_green = tint_env0_green
+        self._tinted = False
+        self._tokens_list = None   # list of (T, 64) np.float32, one per env slot
+        self._step = 0
+        self._orig_decode = None
+        self._installed = False
+
+    def _load_tokens(self) -> None:
+        paths = [p for p in self.token_npz.split(",") if p]
+        self._tokens_list = []
+        for p in paths:
+            d = np.load(p, allow_pickle=True)
+            t = np.asarray(d["motion_token"], dtype=np.float32)
+            self._tokens_list.append(t)
+            logger.info(
+                f"[vla_injector] env slot {len(self._tokens_list)-1}: {t.shape} from {p} "
+                f"(key={d.get('motion_key')}, prompt={d.get('prompt')})"
+            )
+
+    def _install_hook(self) -> None:
+        import torch
+
+        actor_module = self.model.policy.actor_module
+        orig = actor_module.decode
+        want = self.decoder_name
+        self._orig_decode = orig
+
+        def wrapped(decoder_name, decode_input_dict, token_mask=None):
+            if decoder_name == want and "token_flattened" in decode_input_dict:
+                ref = decode_input_dict["token_flattened"]            # (num_envs, 64) flattened
+                rep = ref.clone()
+                n_env = ref.shape[0]
+                for e in range(n_env):
+                    toks = self._tokens_list[e % len(self._tokens_list)]
+                    idx = self._step % len(toks) if self.loop else min(self._step, len(toks) - 1)
+                    rep[e] = torch.as_tensor(
+                        toks[idx], device=ref.device, dtype=ref.dtype
+                    ).reshape(rep[e].shape)
+                decode_input_dict = {**decode_input_dict, "token_flattened": rep}
+                self._step += 1
+            return orig(decoder_name, decode_input_dict, token_mask=token_mask)
+
+        actor_module.decode = wrapped
+        self._installed = True
+        logger.info(f"[vla_injector] decode hook installed (decoder='{want}', loop={self.loop})")
+
+    # eval loop calls on_step_end on every callback BEFORE the rollout loop -> install here
+    def on_step_end(self, *args, **kwargs) -> None:
+        if self.model is None and kwargs.get("model") is not None:
+            self.model = kwargs["model"]
+        if self.model is not None and not self._installed:
+            if self._tokens_list is None:
+                self._load_tokens()
+            self._install_hook()
+
+    def _tint_teacher(self) -> None:
+        """Bind a translucent-green material to env_0's robot meshes (reference/teacher)."""
+        try:
+            import omni.usd
+            from pxr import Gf, Sdf, UsdGeom, UsdShade
+
+            stage = omni.usd.get_context().get_stage()
+            mtl_path = "/World/Looks/TeacherGreen"
+            mtl = UsdShade.Material.Define(stage, mtl_path)
+            shader = UsdShade.Shader.Define(stage, mtl_path + "/Shader")
+            shader.CreateIdAttr("UsdPreviewSurface")
+            shader.CreateInput("diffuseColor", Sdf.ValueTypeNames.Color3f).Set(
+                Gf.Vec3f(0.05, 0.85, 0.15)
+            )
+            shader.CreateInput("roughness", Sdf.ValueTypeNames.Float).Set(0.6)
+            mtl.CreateSurfaceOutput().ConnectToSource(shader.ConnectableAPI(), "surface")
+
+            from pxr import Usd
+
+            root = "/World/envs/env_0/Robot"
+            # de-instance env_0's robot (the asset is instanceable for perf) so its meshes
+            # become real, editable prims — otherwise they're read-only instance proxies.
+            root_prim = stage.GetPrimAtPath(root)
+            if root_prim and root_prim.IsValid():
+                for p in Usd.PrimRange(root_prim, Usd.TraverseInstanceProxies()):
+                    pass
+                # flip instanceable off on the robot subtree (root + any instanceable child)
+                root_prim.SetInstanceable(False)
+                for child in Usd.PrimRange(root_prim):
+                    if child.IsInstanceable():
+                        child.SetInstanceable(False)
+            n = 0
+            # descend into instance proxies (replicated envs are USD instances)
+            rng = Usd.PrimRange(stage.GetPrimAtPath("/World/envs/env_0"),
+                                Usd.TraverseInstanceProxies())
+            sample = []
+            for prim in rng:
+                if prim.IsA(UsdGeom.Mesh):
+                    if len(sample) < 3:
+                        sample.append(prim.GetPath().pathString)
+                    tgt = prim
+                    if prim.IsInstanceProxy():
+                        # cannot edit an instance proxy; recolor via displayColor on the
+                        # authoring path is also blocked -> fall back to gprim displayColor
+                        pass
+                    try:
+                        UsdShade.MaterialBindingAPI(tgt).Bind(
+                            mtl, bindingStrength=UsdShade.Tokens.strongerThanDescendants
+                        )
+                        n += 1
+                    except Exception:  # noqa: BLE001
+                        # instance proxy: try authoring displayColor instead
+                        try:
+                            UsdGeom.Gprim(tgt).GetDisplayColorAttr().Set(
+                                [Gf.Vec3f(0.05, 0.85, 0.15)]
+                            )
+                            n += 1
+                        except Exception:  # noqa: BLE001
+                            pass
+            logger.info(
+                f"[vla_injector] tint env_0: bound {n} meshes; sample={sample}; "
+                f"(0 + instancing -> per-env recolor blocked)"
+            )
+        except Exception as exc:  # noqa: BLE001
+            logger.warning(f"[vla_injector] tint_env0_green failed: {exc}")
+
+    def eval_step(self, env, results) -> bool:
+        if self.tint_env0_green and not self._tinted:
+            self._tint_teacher()
+            self._tinted = True
+        # results = (obs, rewards, dones, infos); on episode reset, restart token playback.
+        try:
+            dones = results[2]
+            if hasattr(dones, "any") and bool(dones.any()):
+                self._step = 0
+        except Exception:  # noqa: BLE001
+            pass
+        return False  # never exit; user closes the viewer window

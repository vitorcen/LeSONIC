--- /dev/null
+++ b/gear_sonic/data/vla_token_recorder.py
@@ -0,0 +1,208 @@
+"""VLA token recorder — eval-callback that taps SONIC motion tokens during Isaac eval.
+
+Architecture-side VLA route (Path T1, step 1): while the released SONIC WBC tracks a
+reference motion, capture the 64-dim FSQ ``motion_token`` the actor emits each step,
+plus the ego camera frame and robot proprioception, and dump one ``.npz`` per episode.
+
+This runs INSIDE the isaaclab conda env (Isaac Sim + gear_sonic). It deliberately does
+NOT touch lerobot — the GR00T-WholeBodyControl exporter needs the old ``lerobot.common``
+layout which conflicts with our lerobot. A separate offline converter turns these raw
+``.npz`` episodes into the ``UNITREE_G1_SONIC`` LeRobot dataset.
+
+Token tap: the actor is ``model.policy.actor_module`` (UniversalTokenModule). We wrap its
+``decode("g1_dyn", {token_flattened, proprioception})`` and grab ``token_flattened`` — the
+exact 64-dim vector the C++ deploy publishes as ``proprio["token_state"]``.
+
+Registered as an eval-callback (``eval_callbacks=[vla_recorder]``); the eval loop sets
+``callback.model`` and calls ``eval_step(env, results)`` every step. Returning ``True``
+signals the loop to exit (which then ``os._exit(0)``s cleanly).
+"""
+
+from __future__ import annotations
+
+from collections import defaultdict
+import os
+from pathlib import Path
+
+import numpy as np
+
+try:
+    from loguru import logger
+except Exception:  # pragma: no cover - loguru always present in this env
+    import logging
+
+    logger = logging.getLogger(__name__)
+
+
+class VlaTokenRecorder:
+    """Eval-callback: record (motion_token, ego_rgb, proprio) into one npz per episode."""
+
+    # The eval loop injects the live model here when this is None.
+    model = None
+
+    def __init__(
+        self,
+        output_dir: str,
+        motion_key: str,
+        prompt: str,
+        max_steps: int = 0,
+        warmup_steps: int = 5,
+        episode_tag: str = "000",
+        camera_key: str = "ego_camera",
+        decoder_name: str = "g1_dyn",
+        env_index: int = 0,
+    ):
+        self.output_dir = output_dir
+        self.motion_key = motion_key
+        self.prompt = prompt
+        self.max_steps = int(max_steps)
+        self.warmup_steps = int(warmup_steps)
+        self.episode_tag = str(episode_tag)
+        self.camera_key = camera_key
+        self.decoder_name = decoder_name
+        self.env_index = int(env_index)
+
+        self._hook_installed = False
+        self._orig_decode = None
+        self._token_capture: dict = {}
+        self._scene_ref = None
+        self._buf: dict[str, list] = defaultdict(list)
+        self._step = 0
+        self._saved = False
+
+    # --- trainer-callback surface (eval loop calls on_step_end on every cb) ---
+    def on_step_end(self, *args, **kwargs) -> None:
+        # The eval loop injects the live model here (same pattern as ImEvalCallback).
+        if self.model is None and kwargs.get("model") is not None:
+            self.model = kwargs["model"]
+
+    # --- token tap -------------------------------------------------------
+    def _install_hook(self) -> None:
+        actor_module = self.model.policy.actor_module
+        orig = actor_module.decode
+        cap = self._token_capture
+        want = self.decoder_name
+
+        def wrapped(decoder_name, decode_input_dict, token_mask=None):
+            if decoder_name == want and "token_flattened" in decode_input_dict:
+                cap["token"] = decode_input_dict["token_flattened"].detach()
+            return orig(decoder_name, decode_input_dict, token_mask=token_mask)
+
+        actor_module.decode = wrapped
+        self._orig_decode = orig
+        logger.info(
+            f"[vla_recorder] decode hook installed on actor_module (decoder='{want}')"
+        )
+
+    def _restore_hook(self) -> None:
+        if self._orig_decode is not None:
+            self.model.policy.actor_module.decode = self._orig_decode
+            self._orig_decode = None
+
+    # --- scene resolution (callback gets the wrapper) --------------------
+    @staticmethod
+    def _resolve_scene(env):
+        for getter in (
+            lambda e: e.env.scene,
+            lambda e: e.scene,
+            lambda e: e.env.unwrapped.scene,
+        ):
+            try:
+                scene = getter(env)
+                _ = scene["robot"]
+                return scene
+            except Exception:  # noqa: BLE001
+                continue
+        raise RuntimeError("[vla_recorder] could not resolve env scene")
+
+    # --- per-step hook ---------------------------------------------------
+    def eval_step(self, env, results) -> bool:
+        if self._saved:
+            return True
+        if not self._hook_installed:
+            assert self.model is not None, "[vla_recorder] model not injected by eval loop"
+            self._install_hook()
+            self._scene_ref = self._resolve_scene(env)
+            self._hook_installed = True
+            logger.info(
+                f"[vla_recorder] motion='{self.motion_key}' prompt='{self.prompt}' "
+                f"max_steps={self.max_steps} camera='{self.camera_key}'"
+            )
+
+        # Warmup: let the camera/physics settle before recording.
+        if self._step < self.warmup_steps:
+            self._step += 1
+            return False
+
+        scene = self._scene_ref
+        tok = self._token_capture.get("token")
+        if tok is None:
+            # Actor hasn't produced a token yet this step; skip (do not advance buffer).
+            self._step += 1
+            return False
+
+        i = self.env_index
+        robot = scene["robot"]
+        joint_pos = robot.data.joint_pos[i].detach().cpu().numpy().astype(np.float32)
+        root_quat = robot.data.root_quat_w[i].detach().cpu().numpy().astype(np.float32)
+
+        rgb = None
+        try:
+            cam = scene[self.camera_key]
+            rgb_t = cam.data.output["rgb"][i]
+            rgb = rgb_t.detach().cpu().numpy()[..., :3].astype(np.uint8)
+        except Exception as exc:  # noqa: BLE001
+            if not self._buf["_warned_cam"]:
+                logger.warning(f"[vla_recorder] no camera '{self.camera_key}': {exc}")
+                self._buf["_warned_cam"].append(1)
+
+        # token_flattened is (num_envs, num_tokens, token_dim) or (num_envs, 64);
+        # flatten env i to a flat 64-vector.
+        self._buf["motion_token"].append(
+            tok[i].detach().cpu().numpy().reshape(-1).astype(np.float32)
+        )
+        self._buf["joint_pos"].append(joint_pos)
+        self._buf["root_quat"].append(root_quat)
+        if rgb is not None:
+            self._buf["ego_rgb"].append(rgb)
+
+        self._step += 1
+        recorded = len(self._buf["motion_token"])
+        if self.max_steps > 0 and recorded >= self.max_steps:
+            self._save()
+            return True
+        return False
+
+    # --- persistence -----------------------------------------------------
+    def _save(self) -> None:
+        if self._saved:
+            return
+        out_dir = Path(self.output_dir) / self.motion_key
+        out_dir.mkdir(parents=True, exist_ok=True)
+        out_path = out_dir / f"episode_{self.episode_tag}.npz"
+
+        payload = {
+            "motion_token": np.stack(self._buf["motion_token"]),  # (T, 64)
+            "joint_pos": np.stack(self._buf["joint_pos"]),        # (T, J)
+            "root_quat": np.stack(self._buf["root_quat"]),        # (T, 4) wxyz
+            "fps": np.int64(50),
+            "prompt": str(self.prompt),
+            "motion_key": str(self.motion_key),
+        }
+        if self._buf["ego_rgb"]:
+            payload["ego_rgb"] = np.stack(self._buf["ego_rgb"])   # (T, H, W, 3) uint8
+
+        np.savez_compressed(out_path, **payload)
+        self._restore_hook()
+        self._saved = True
+        T = payload["motion_token"].shape[0]
+        cam_shape = payload["ego_rgb"].shape if "ego_rgb" in payload else "NO-CAMERA"
+        logger.info(
+            f"[vla_recorder] SAVED {out_path}  T={T}  token={payload['motion_token'].shape} "
+            f"ego_rgb={cam_shape}"
+        )
+
+    # The eval loop may break for other reasons; flush whatever we have.
+    def on_eval_end(self, *args, **kwargs) -> None:  # best-effort
+        if not self._saved and self._buf["motion_token"]:
+            self._save()

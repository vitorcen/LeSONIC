+"""VLA LIVE injector — close the loop: GR00T-in-the-loop drives SONIC's WBC.
+
+Counterpart to vla_token_injector (which replays an OFFLINE token npz). This one queries a
+running GR00T inference server every control step: it builds the GR00T observation from the
+LIVE Isaac env (ego camera + proprioception + projected_gravity + language prompt), sends it
+over ZMQ to ``gr00t.eval.run_gr00t_server`` (running in the GR00T venv), receives a
+``(action_horizon, 64)`` motion_token chunk, and feeds it one token per step into SONIC's
+``decode("g1_dyn", {token_flattened, ...})``. The WBC turns GR00T's tokens into balanced
+joints — so the viewer shows the genuine closed loop: env state -> GR00T -> token -> WBC -> G1,
+with NO C++/DDS and NO precomputed tokens.
+
+Why this is the real derisk (vs the offline injector): here GR00T sees the ACTUAL drifted env
+state (the WBC decode isn't a perfect tracker, so the robot leaves the recorded trajectory),
+so it must produce good tokens for states it never saw during the open-loop dump.
+
+Runs INSIDE the isaaclab conda env (no ``gr00t`` package), so it speaks the GR00T ZMQ wire
+protocol with a tiny standalone client (msgpack-numpy, the same MsgSerializer format).
+
+Obs assembly mirrors scripts/sonic_vla_npz_to_lerobot.py EXACTLY (consistency > correctness:
+the model learned on whatever the converter produced):
+  - observation.state := _fit(joint_pos, 43), then sliced per meta/modality.json into
+    left_leg[0:6] right_leg[6:12] waist[12:15] left_arm[15:22] left_hand[22:29]
+    right_arm[29:36] right_hand[36:43]
+  - projected_gravity := compute_projected_gravity(root_quat)   (3,)
+  - ego_view := scene["ego_camera"].rgb                          (480,640,3) u8
+  - language := the prompt string
+The GR00T server normalizes internally, so we send RAW values (validated against the dump).
+
+Action chunking: GR00T returns 40 tokens (action_horizon). We consume one per control step
+and re-query when the chunk is exhausted — the query happens in eval_step (which has the env),
+the decode hook only consumes the buffered chunk (clean 1-chunk lag, inherent to chunked VLA).
+
+TIMELINE mode (sequence one prompt after another in a SINGLE running session — no GUI restart):
+  Pass ``timeline_json`` pointing at a file like
+    {"segments": [
+       {"prompt": "squat",  "steps": 200},
+       {"prompt": "walk and turn around", "steps": 300,
+        "settle_steps": 40, "bootstrap_npz": ".../walk.npz", "bootstrap_steps": 80},
+       {"prompt": "kick", "steps": 200,
+        "settle_steps": 40, "bootstrap_npz": ".../kick.npz", "bootstrap_steps": 80}]}
+  Each segment runs for ``steps`` control steps, then the injector advances to the next:
+    - it swaps the prompt sent to the (stateless) GR00T server — no server restart, no GUI reload;
+    - an optional ``settle_steps`` window at the segment start returns the robot to a neutral
+      anchor (inject ``neutral_npz`` if given, else freeze the last pose) so the seam is smooth;
+    - an optional ``bootstrap`` window then drives INTO a one-shot motion (kick/walk/jump) before
+      handing back to live GR00T — same crutch as the single-motion path, per segment.
+  Single-prompt mode (no timeline_json) is unchanged: one infinite segment using ``prompt``.
+"""
+
+from __future__ import annotations
+
+import json
+import os
+
+import numpy as np
+
+try:
+    from loguru import logger
+except Exception:  # pragma: no cover
+    import logging
+
+    logger = logging.getLogger(__name__)
+
+# P0 #1: GR00T's flow-matching head regresses the 64-d motion_token as a *continuous*
+# target, but the token is an FSQ code living on a discrete grid — step 1/16 (0.0625),
+# num_fsq_levels=32 (per gear_sonic/config/.../all_mlp_v1.yaml). The recorded dataset
+# spans k/16 for k in [-13, 13] = [-0.8125, +0.8125] (measured on sonic_vla_lerobot_resampled3;
+# the extreme levels just don't appear in our motions). BUG FIX 2026-06-25: the old clamp
+# was [-0.5, 0.5] (k in [-8, 8]) — it TRUNCATED every legitimate code with |tok|>0.5, i.e.
+# the high-amplitude tokens at motion peaks (e.g. a kick's leg extension reaches 0.8125),
+# decapitating the motion. Widen to the real 32-level codebook bound (|k|<=16 -> ±1.0);
+# round() already snaps to the 1/16 grid so clamp only rejects blown-up OOD predictions.
+# Gate with SONIC_SNAP_GRID=0 to A/B against the raw continuous token.
+_SNAP_FSQ = os.environ.get("SONIC_SNAP_GRID", "1") != "0"
+
+
+def _snap_fsq_grid(tok):
+    """Round a torch token to the nearest FSQ grid value and clamp to the 32-level codebook."""
+    import torch
+
+    return torch.clamp(torch.round(tok * 16.0) / 16.0, -1.0, 1.0)
+
+
+# observation.state slices, from datasets/sonic_vla_lerobot/meta/modality.json.
+# Order matches the server's modality_config state keys (group -> slice into the 43-vec).
+_STATE_SLICES = {
+    "left_leg": (0, 6),
+    "right_leg": (6, 12),
+    "waist": (12, 15),
+    "left_arm": (15, 22),
+    "left_hand": (22, 29),
+    "right_arm": (29, 36),
+    "right_hand": (36, 43),
+}
+_STATE_DIM = 43
+
+
+def _fit(vec: np.ndarray, n: int) -> np.ndarray:
+    """Truncate / zero-pad a 1-D vector to length n — identical to the converter's _fit."""
+    vec = np.asarray(vec).reshape(-1)
+    if vec.shape[0] == n:
+        return vec
+    out = np.zeros(n, dtype=vec.dtype)
+    k = min(n, vec.shape[0])
+    out[:k] = vec[:k]
+    return out
+
+
+def _load_tokens(npz_path: str) -> np.ndarray | None:
+    """Load a (T, 64) motion_token array from an npz dump, or None if no path."""
+    if not npz_path:
+        return None
+    return np.asarray(
+        np.load(npz_path, allow_pickle=True)["motion_token"], dtype=np.float32
+    ).reshape(-1, 64)
+
+
+class _Gr00tWireClient:
+    """Minimal ZMQ REQ client speaking the gr00t PolicyServer wire (msgpack-numpy)."""
+
+    def __init__(self, host: str, port: int, timeout_ms: int = 20000):
+        import msgpack_numpy as mnp
+        import zmq
+
+        self._mnp = mnp
+        self._zmq = zmq
+        self.host, self.port, self.timeout_ms = host, port, timeout_ms
+        self.context = zmq.Context()
+        self._connect()
+
+    def _connect(self) -> None:
+        self.socket = self.context.socket(self._zmq.REQ)
+        self.socket.setsockopt(self._zmq.RCVTIMEO, self.timeout_ms)
+        self.socket.setsockopt(self._zmq.SNDTIMEO, self.timeout_ms)
+        self.socket.connect(f"tcp://{self.host}:{self.port}")
+
+    def _call(self, endpoint: str, data: dict | None, requires_input: bool = True):
+        req = {"endpoint": endpoint}
+        if requires_input:
+            req["data"] = data
+        try:
+            self.socket.send(self._mnp.packb(req))
+            msg = self.socket.recv()
+        except self._zmq.error.Again:
+            self._connect()  # timed-out REQ socket is dead; recreate for next call
+            raise
+        if msg == b"ERROR":
+            raise RuntimeError("[vla_live] GR00T server returned ERROR")
+        resp = self._mnp.unpackb(msg, raw=False)
+        if isinstance(resp, dict) and "error" in resp:
+            raise RuntimeError(f"[vla_live] server error: {resp['error']}")
+        return resp
+
+    def ping(self) -> bool:
+        try:
+            self._call("ping", None, requires_input=False)
+            return True
+        except Exception:  # noqa: BLE001
+            return False
+
+    def get_action(self, observation: dict) -> dict:
+        # server spreads request['data'] as kwargs -> get_action(observation=..., options=...)
+        resp = self._call("get_action", {"observation": observation, "options": None})
+        action = resp[0] if isinstance(resp, (list, tuple)) else resp
+        return action
+
+
+class VlaLiveInjector:
+    """Eval-callback: drive SONIC's decoder with tokens a live GR00T server predicts.
+
+    Supports a single prompt (default) or a ``timeline_json`` of prompt segments played
+    back-to-back in one running session (see module docstring).
+    """
+
+    model = None  # injected by the eval loop
+
+    def __init__(self, host: str = "127.0.0.1", port: int = 5555, prompt: str = "",
+                 action_horizon: int = 40, decoder_name: str = "g1_dyn",
+                 camera_key: str = "ego_camera", env_index: int = 0,
+                 bootstrap_npz: str = "", bootstrap_steps: int = 0,
+                 timeline_json: str = ""):
+        self.host = host
+        self.port = int(port)
+        self.prompt = prompt
+        self.action_horizon = int(action_horizon)
+        self.decoder_name = decoder_name
+        self.camera_key = camera_key
+        self.env_index = int(env_index)
+
+        # Timeline: a list of segments. Single-prompt mode = one infinite segment, so the
+        # rest of the class only ever reasons about "the current segment".
+        self._segments = self._build_segments(
+            timeline_json, prompt, bootstrap_npz, bootstrap_steps
+        )
+        # Total scripted length: timeline loops modulo this so every segment keeps its own step
+        # budget and the sequence cycles cleanly. None when any segment is open-ended (the
+        # single-prompt path uses one steps=None segment that never ends).
+        _steps = [s["steps"] for s in self._segments]
+        self._total_steps = None if any(s is None for s in _steps) else sum(_steps)
+        self._seg_idx = -1            # force a segment-entry log on the first step
+
+        self._client = None
+        self._scene = None
+        self._orig_decode = None
+        self._installed = False
+        self._chunk = None            # (action_horizon, 64) float32 — latest live GR00T chunk
+        self._chunk_pos = 10**9       # force a query on the first eval_step
+        self._global_t = 0            # control steps since start (drives the timeline)
+        self._last_src = None         # last token injected (for settle "freeze" without neutral)
+        self._stand_token = None      # captured reset-pose token; injected (frozen) while idle
+        self._idle_loop = None        # natural standing micro-motion loop (VLA_IDLE_NPZ); None until first idle
+        self._n_query = 0
+        self._warned_cam = False
+
+    # --- timeline construction -----------------------------------------
+    @staticmethod
+    def _build_segments(timeline_json, prompt, bootstrap_npz, bootstrap_steps):
+        """Normalize timeline_json (or the single-prompt args) into a list of segments."""
+        if timeline_json:
+            with open(timeline_json) as fh:
+                spec = json.load(fh)
+            global_neutral = spec.get("neutral_npz", "")
+            segs = []
+            for s in spec["segments"]:
+                neutral_path = s.get("neutral_npz", global_neutral)
+                segs.append({
+                    "prompt": s["prompt"],
+                    "steps": s.get("steps"),                  # None => runs forever (last seg)
+                    "settle_steps": int(s.get("settle_steps", 0)),
+                    "bootstrap": _load_tokens(s.get("bootstrap_npz", "")),
+                    "bootstrap_steps": int(s.get("bootstrap_steps", 0)),
+                    "neutral": _load_tokens(neutral_path),
+                })
+            return segs
+        # single-prompt mode: one infinite segment, identical behavior to before.
+        return [{
+            "prompt": prompt,
+            "steps": None,
+            "settle_steps": 0,
+            "bootstrap": _load_tokens(bootstrap_npz),
+            "bootstrap_steps": int(bootstrap_steps),
+            "neutral": None,
+        }]
+
+    def _current_segment(self):
+        """Resolve (segment_index, local_step, segment) for the current global step.
+
+        Timeline mode LOOPS: global_t is taken modulo the total scripted length, so the sequence
+        cycles cleanly (each segment gets exactly its step budget — no open-ended last segment
+        hogging the loop) without needing an episode reset. Single-prompt mode has one steps=None
+        segment that never ends and just counts from the absolute global step.
+        """
+        total = self._total_steps
+        t = self._global_t if total is None else self._global_t % total
+        start = 0
+        for i, seg in enumerate(self._segments):
+            steps = seg["steps"]
+            if steps is None:
+                return i, self._global_t - start, seg          # infinite (single-prompt)
+            if t < start + steps:
+                return i, t - start, seg                       # local step within this segment
+            start += steps
+        last = len(self._segments) - 1                          # unreachable once modulo'd
+        return last, t - (start - self._segments[last]["steps"]), self._segments[last]
+
+    # --- eval-loop surface ----------------------------------------------
+    def on_step_end(self, *args, **kwargs) -> None:
+        if self.model is None and kwargs.get("model") is not None:
+            self.model = kwargs["model"]
+        if self.model is not None and not self._installed:
+            self._install_hook()
+
+    def _install_hook(self) -> None:
+        actor_module = self.model.policy.actor_module
+        orig = actor_module.decode
+        want = self.decoder_name
+        self._orig_decode = orig
+
+        def wrapped(decoder_name, decode_input_dict, token_mask=None):
+            if decoder_name == want and "token_flattened" in decode_input_dict:
+                if self._stand_token is None:   # capture the reset standing pose once, for idle hold
+                    self._stand_token = (
+                        decode_input_dict["token_flattened"][0].detach().cpu().numpy().copy())
+                src = self._pick_source()
+                if src is not None:
+                    self._inject(decode_input_dict, src)
+                    decode_input_dict = {**decode_input_dict,
+                                         "token_flattened": self._injected}
+                self._global_t += 1
+            return orig(decoder_name, decode_input_dict, token_mask=token_mask)
+
+        actor_module.decode = wrapped
+        self._installed = True
+        logger.info(
+            f"[vla_live] decode hook installed (decoder='{want}', server={self.host}:{self.port}, "
+            f"action_horizon={self.action_horizon}, segments={len(self._segments)})"
+        )
+
+    def _is_idle(self) -> bool:
+        """Idle = hold the standing reset pose, never query the model (inject the captured stand token).
+
+        VLA_STAND_MODEL=1: "stand" is now a TRAINED motion (macarena standing front) — route it
+        THROUGH the model so idle is natural standing micro-motion (not a dead-frozen zero-velocity
+        token). This keeps the robot out of the deepest freeze basin, so switching from idle to a
+        fragile motion (kick/walk/jump) can initiate. Only empty/none/idle stay sentinel-held."""
+        p = self.prompt.strip().lower()
+        if os.environ.get("VLA_STAND_MODEL"):
+            return p in ("", "none", "idle")
+        return p in ("", "stand", "idle", "none", "stand still", "站立", "站着")
+
+    def _pick_source(self):
+        """Choose the token to inject this step from the current segment's windows.
+
+        Order within a segment: settle (neutral / freeze) -> bootstrap (drive in) -> live.
+        """
+        import torch  # noqa: F401  (ensures torch is importable in this env)
+
+        if self._is_idle():
+            # idle: replay a captured NATURAL standing micro-motion loop (real mocap stand-sway from
+            # a clip's settle segment) so the robot keeps a small nonzero velocity instead of a dead
+            # zero-velocity hold. This breaks the cold-standing freeze attractor: switching to a
+            # fragile motion (kick/walk/jump) from this dynamic idle initiates, whereas from a dead
+            # hold it collapses. VLA_IDLE_NPZ overrides the loop; falls back to the frozen pose.
+            if self._idle_loop is None and os.environ.get("VLA_IDLE_NPZ"):
+                try:
+                    self._idle_loop = np.load(os.environ["VLA_IDLE_NPZ"])["motion_token"].astype(np.float32)
+                    logger.info(f"[vla_live] idle natural-sway loop loaded: {self._idle_loop.shape}")
+                except Exception as exc:  # noqa: BLE001
+                    logger.warning(f"[vla_live] idle loop load failed ({exc!r}); holding stand pose")
+                    self._idle_loop = False
+            if self._idle_loop is not None and self._idle_loop is not False and self._stand_token is not None:
+                return self._idle_loop[self._global_t % len(self._idle_loop)]
+            return self._stand_token                     # fallback: hold reset standing pose
+        _, lt, seg = self._current_segment()             # lt = step within this segment
+        settle, boot_n = seg["settle_steps"], seg["bootstrap_steps"]
+        src = None
+        if lt < settle:
+            # settle window: return to a neutral anchor before the next move.
+            if seg["neutral"] is not None:
+                src = seg["neutral"][lt % len(seg["neutral"])]
+            else:
+                src = self._last_src                     # freeze: hold the last pose
+        elif seg["bootstrap"] is not None and lt < settle + boot_n:
+            # bootstrap window: replay open-loop dump tokens to enter a one-shot motion.
+            bi = (lt - settle) % len(seg["bootstrap"])
+            src = seg["bootstrap"][bi]
+        elif self._chunk is not None:
+            # live window: follow GR00T's latest chunk.
+            src = self._chunk[min(self._chunk_pos, self.action_horizon - 1)]
+            self._chunk_pos += 1
+        if src is not None:
+            self._last_src = src
+        return src
+
+    def _inject(self, decode_input_dict, src) -> None:
+        """Overwrite token_flattened for all envs with ``src`` (snapped to the FSQ grid)."""
+        import torch
+
+        ref = decode_input_dict["token_flattened"]       # (num_envs, 64)
+        rep = ref.clone()
+        tok = torch.as_tensor(np.asarray(src).copy(), device=ref.device, dtype=ref.dtype)
+        if _SNAP_FSQ:
+            tok = _snap_fsq_grid(tok)                     # pull live token onto FSQ grid
+        rep[:] = tok.reshape(rep[0].shape)               # all envs follow injected token
+        self._injected = rep
+
+    @staticmethod
+    def _resolve_scene(env):
+        for getter in (lambda e: e.env.scene, lambda e: e.scene, lambda e: e.env.unwrapped.scene):
+            try:
+                scene = getter(env)
+                _ = scene["robot"]
+                return scene
+            except Exception:  # noqa: BLE001
+                continue
+        raise RuntimeError("[vla_live] could not resolve env scene")
+
+    # --- re-anchor: deploy-side onset fix (codex-ranked #1, no retrain) ---------------
+    # The freeze is an OOD-proprio problem: after the robot drifts (root/pose wander off the
+    # narrow in-distribution standing band), switching to a fragile motion (kick/jump/walk)
+    # collapses to a hold chunk. The user found a viewer R-reset (teleport to the reference
+    # stand) restores the kick. This reproduces that programmatically: continuously snapshot a
+    # CLEAN in-dist stand pose (held near the origin), and on a drifted switch to a fragile
+    # motion write it back so the VLA sees an in-distribution proprio again. Gate: VLA_REANCHOR=1.
+    _FRAGILE = ("kick", "jump", "walk")
+
+    def _capture_anchor(self) -> None:
+        """Snapshot the latest clean standing pose (idle/stand prompt, root near origin)."""
+        if not os.environ.get("VLA_REANCHOR") or self._scene is None or self._global_t <= 60:
+            return
+        p = self.prompt.strip().lower()
+        if not (self._is_idle() or p in ("stand", "stand still", "站立", "站着")):
+            return
+        try:
+            import torch  # noqa: F401
+            robot = self._scene["robot"]; i = self.env_index
+            rxy = robot.data.root_pos_w[i, :2].detach()
+            if float((rxy[0] ** 2 + rxy[1] ** 2) ** 0.5) < 0.25:    # near origin = in-dist stand
+                self._anchor_qpos = robot.data.joint_pos[i].detach().clone()
+                self._anchor_root = robot.data.root_state_w[i].detach().clone()
+        except Exception:  # noqa: BLE001
+            pass
+
+    def _maybe_reanchor(self, new_prompt: str) -> None:
+        """On a switch to a fragile motion, if the robot has drifted, restore the clean stand."""
+        if not os.environ.get("VLA_REANCHOR") or self._scene is None:
+            return
+        pl = new_prompt.strip().lower()
+        if not any(f in pl for f in self._FRAGILE):
+            return
+        anc = getattr(self, "_anchor_qpos", None)
+        if anc is None:
+            logger.info("[vla_live] re-anchor: no clean stand captured yet, skip")
+            return
+        try:
+            import torch
+            robot = self._scene["robot"]; i = self.env_index
+            q = robot.data.joint_pos[i].detach()
+            n = min(anc.shape[0], q.shape[0])
+            dist = float(torch.linalg.norm(q[:n] - anc[:n]))
+            thr = float(os.environ.get("VLA_REANCHOR_THR", "0.20"))
+            force = bool(os.environ.get("VLA_REANCHOR_FORCE"))   # DIAG: always re-anchor (isolate teleport effect)
+            if dist < thr and not force:
+                logger.info(f"[vla_live] re-anchor SKIP: pose in-band (dist {dist:.3f} < {thr})")
+                return
+            eid = torch.tensor([i], device=anc.device)
+            keep_vel = bool(os.environ.get("VLA_REANCHOR_NO_ZERO_VEL"))  # DIAG: preserve micro-sway velocity
+            jv = robot.data.joint_vel[i].detach().clone() if keep_vel else torch.zeros_like(robot.data.joint_vel[i])
+            robot.write_joint_state_to_sim(anc.unsqueeze(0), jv.unsqueeze(0), env_ids=eid)
+            root = getattr(self, "_anchor_root", None)
+            if root is not None:
+                root = root.clone()
+                if not keep_vel:
+                    root[7:] = 0.0                            # zero lin+ang velocity for a static stand
+                robot.write_root_state_to_sim(root.unsqueeze(0), env_ids=eid)
+            self._chunk = None; self._chunk_pos = 10**9      # force a fresh query from the restored pose
+            logger.info(f"[vla_live] RE-ANCHOR -> clean in-dist stand (dist {dist:.3f}, thr {thr}, "
+                        f"force={force}, keep_vel={keep_vel}) before '{new_prompt}'")
+        except Exception as exc:  # noqa: BLE001
+            logger.warning(f"[vla_live] re-anchor failed: {exc!r}")
+
+    # --- build the GR00T observation from the live env ------------------
+    def _build_obs(self, prompt: str | None = None) -> dict:
+        from gear_sonic.utils.data_collection.transforms import compute_projected_gravity
+
+        i = self.env_index
+        robot = self._scene["robot"]
+        joint_pos = robot.data.joint_pos[i].detach().cpu().numpy().astype(np.float32)
+        root_quat = robot.data.root_quat_w[i].detach().cpu().numpy().astype(np.float32)
+        self._cur_joint_pos = joint_pos.copy()   # for the per-query motion-magnitude log
+        # pelvis pose — height is a cheap "did it fall" signal (standing G1 ~0.74m; <0.4 = fallen);
+        # X/Y diagnose the "flash back to origin" report (does the robot root teleport to ~0?).
+        try:
+            rp = robot.data.root_pos_w[i].detach().cpu().numpy()
+            self._root_z = float(rp[2]); self._root_x = float(rp[0]); self._root_y = float(rp[1])
+        except Exception:  # noqa: BLE001
+            self._root_z = self._root_x = self._root_y = float("nan")
+        state_vec = _fit(joint_pos, _STATE_DIM).astype(np.float32)
+        # DIAG (2026-06-24): override the FIRST-query proprio with the GT frame-0 state (43-vec,
+        # modality order). Tests whether correcting the reset-pose OOD un-freezes one-shot motions
+        # (kick/jump/walk) — the cross-substitution proved proprio (not image/gravity) drives the
+        # frozen-chunk collapse. No token replay: the VLA still generates all actions.
+        if os.environ.get("VLA_GT_PROPRIO_NPZ") and self._n_query == 0:
+            gv = np.load(os.environ["VLA_GT_PROPRIO_NPZ"])["state43"].astype(np.float32)
+            state_vec = _fit(gv, _STATE_DIM).astype(np.float32)
+        proj_grav = np.asarray(compute_projected_gravity(root_quat), dtype=np.float32).reshape(-1)[:3]
+        # FIX (2026-06-24): the training dataset's projected_gravity is identically [0,0,0]
+        # (a data-collection bug), so at deploy the real gravity vector is OOD on a channel the
+        # head only ever saw as zero. VLA_ZERO_GRAVITY=1 sends zeros to match training exactly.
+        if os.environ.get("VLA_ZERO_GRAVITY"):
+            proj_grav = np.zeros(3, dtype=np.float32)
+
+        rgb = None
+        try:
+            rgb = self._scene[self.camera_key].data.output["rgb"][i]
+            rgb = rgb.detach().cpu().numpy()[..., :3].astype(np.uint8)
+        except Exception as exc:  # noqa: BLE001
+            if not self._warned_cam:
+                logger.warning(f"[vla_live] no camera '{self.camera_key}': {exc}")
+                self._warned_cam = True
+            rgb = np.zeros((480, 640, 3), dtype=np.uint8)
+
+        # parsed nested obs with (batch=1, T=1, ...) — same layout parse_observation_gr00t makes.
+        state = {k: state_vec[a:b][None, None] for k, (a, b) in _STATE_SLICES.items()}
+        state["projected_gravity"] = proj_grav[None, None]
+        return {
+            "video": {"ego_view": rgb[None, None]},                       # (1,1,480,640,3) u8
+            "state": state,                                              # each (1,1,d) f32
+            "language": {"annotation.human.task_description":
+                         [[self.prompt if prompt is None else prompt]]},
+        }
+
+    @staticmethod
+    def _chunk_from_action(action) -> np.ndarray:
+        """Extract a (horizon, 64) continuous motion_token chunk from a server reply."""
+        mt = action.get("action.motion_token", action.get("motion_token"))
+        mt = np.asarray(mt, dtype=np.float32)
+        if mt.ndim == 3:        # (batch, horizon, 64)
+            mt = mt[0]
+        return mt.reshape(mt.shape[0], -1)                              # (horizon, 64)
+
+    def _query(self) -> None:
+        obs = self._build_obs()
+        chunk = self._chunk_from_action(self._client.get_action(obs))   # cond (prompt)
+        # Classifier-free guidance: amplify the prompt's pull on the CONTINUOUS token
+        # (pre-FSQ-snap). out = uncond + s*(cond - uncond). The null branch ("" prompt)
+        # was trained via prompt-dropout, so uncond is a valid state-only prediction; the
+        # difference (cond - uncond) is what the prompt adds. Scaling it >1 lets a fragile
+        # onset (kick/jump/walk) win over the "hold" prior even from an OOD/drifted stand.
+        # Per-position: full scale on the onset, decay to 1 after, so sustained mid-chunk
+        # tokens aren't over-driven. VLA_CFG_SCALE=1 (default) is a no-op single-pass query.
+        cfg_s = float(os.environ.get("VLA_CFG_SCALE", "1") or "1")
+        cfg_log = ""
+        if cfg_s > 1.0 and not self._is_idle():
+            null_prompt = os.environ.get("VLA_CFG_NULL", "")
+            uncond = self._chunk_from_action(
+                self._client.get_action(self._build_obs(prompt=null_prompt)))
+            H = chunk.shape[0]
+            onset = min(int(os.environ.get("VLA_CFG_ONSET", "12")), H)
+            s = np.full(H, cfg_s, dtype=np.float32)
+            if os.environ.get("VLA_CFG_DECAY", "1") != "0" and H > onset:
+                s[onset:] = np.linspace(cfg_s, 1.0, H - onset, dtype=np.float32)
+            delta = chunk - uncond
+            chunk = uncond + s[:, None] * delta
+            cfg_log = (f" CFG s={cfg_s:.1f} onset={onset} "
+                       f"|cond-uncond|={float(np.linalg.norm(delta) / H):.3f}")
+        self._chunk = chunk
+        self._chunk_pos = 0
+        self._cfg_log = cfg_log
+        # DEBUG: dump obs+token on the first query so we can compare live tokens vs the
+        # offline dump (diagnoses whether the LIVE obs makes GR00T emit a neutral token).
+        if os.environ.get("VLA_LIVE_DEBUG") and self._n_query == 0:
+            st = np.concatenate([v.reshape(-1) for v in obs["state"].values()])
+            img = np.asarray(obs["video"]["ego_view"]).reshape(-1)
+            logger.info(f"[vla_live][DBG] state dim={st.shape[0]} min={st.min():.3f} "
+                        f"max={st.max():.3f} nonzero={np.count_nonzero(st)}/{st.shape[0]}")
+            logger.info(f"[vla_live][DBG] img mean={img.mean():.1f} nonzero_frac="
+                        f"{np.count_nonzero(img)/img.size:.3f}")
+            logger.info(f"[vla_live][DBG] live token[0,:6]={np.round(self._chunk[0,:6],4)}")
+            np.savez(os.environ["VLA_LIVE_DEBUG"], token_chunk=self._chunk,
+                     state=st, img_mean=img.mean(), prompt=self.prompt)
+        # motion magnitude: how far the robot's joints moved since the last query (frozen ~ 0).
+        jp = getattr(self, "_last_joint_pos", None)
+        cur = getattr(self, "_cur_joint_pos", None)
+        dpose = float(np.linalg.norm(cur - jp)) if (jp is not None and cur is not None) else float("nan")
+        self._last_joint_pos = cur
+        self._n_query += 1
+        if self._n_query <= 2 or self._n_query % 10 == 0:
+            z = getattr(self, "_root_z", float("nan"))
+            rx = getattr(self, "_root_x", float("nan")); ry = getattr(self, "_root_y", float("nan"))
+            logger.info(f"[vla_live] query #{self._n_query}: chunk {self._chunk.shape} "
+                        f"root=({rx:.2f},{ry:.2f},{z:.2f}) dpose={dpose:.3f} tok_std={self._chunk.std():.3f} "
+                        f"prompt={self.prompt!r}{getattr(self, '_cfg_log', '')} "
+                        f"{'(FALLEN?)' if z < 0.4 else ''}")
+
+    # --- per-step: advance the timeline + refill the chunk when exhausted
+    def eval_step(self, env, results) -> bool:
+        if self._scene is None:
+            self._scene = self._resolve_scene(env)
+            self._client = _Gr00tWireClient(self.host, self.port)
+            assert self._client.ping(), f"[vla_live] GR00T server not reachable at {self.host}:{self.port}"
+            logger.info(f"[vla_live] connected to GR00T server {self.host}:{self.port}")
+
+        # DIAG (Phase-1 "true exact-reset" test, gated by VLA_RESET_POSE_NPZ=<npz with joint_pos>):
+        # physically write the robot to a real pre-kick / mid-swing pose (Isaac 29-joint order) ONCE
+        # at the start, then let the bootstrap=0 live policy generate from there. Tests whether the
+        # freeze is "can't INITIATE from standing" (sustains from a kickable pose) vs "can't sustain
+        # at all". The env reset is a fixed standing pose regardless of motion, so this is the only
+        # way to start the policy from an in-motion proprio.
+        rp = os.environ.get("VLA_RESET_POSE_NPZ")
+        if rp and not getattr(self, "_pose_written", False) and self._global_t <= 1:
+            try:
+                import torch
+                robot = self._scene["robot"]; i = self.env_index
+                tgt = np.load(rp)["joint_pos"].astype(np.float32)
+                q = robot.data.joint_pos[i].detach().clone()
+                n = min(len(tgt), q.shape[0])
+                q[:n] = torch.as_tensor(tgt[:n], device=q.device, dtype=q.dtype)
+                v = torch.zeros_like(robot.data.joint_vel[i])
+                eid = torch.tensor([i], device=q.device)
+                robot.write_joint_state_to_sim(q.unsqueeze(0), v.unsqueeze(0), env_ids=eid)
+                self._pose_written = True
+                logger.info(f"[vla_live] DIAG reset-pose written from {rp} (n={n})")
+            except Exception as exc:  # noqa: BLE001
+                logger.warning(f"[vla_live] reset-pose write failed: {exc!r}")
+
+        # episode reset -> restart the timeline so playback re-anchors from the start.
+        try:
+            dones = results[2]
+            if hasattr(dones, "any") and bool(dones.any()):
+                logger.info(f"[vla_live] !!! env RESET (dones fired) at global_t={self._global_t} "
+                            f"-> robot teleports to reference origin (this is the 'flash')")
+                self._global_t = 0
+                self._seg_idx = -1
+                self._chunk = None
+                self._chunk_pos = 10**9
+        except Exception:  # noqa: BLE001
+            pass
+
+        # External live prompt control: when VLA_PROMPT_FILE is set, the control file OWNS the
+        # prompt — the looping timeline must NOT reset it on segment re-entry (else it flip-flops
+        # back to the launch prompt every loop). pf computed here so the segment block can respect it.
+        pf = os.environ.get("VLA_PROMPT_FILE")
+
+        # On segment entry: swap the prompt the (stateless) GR00T server sees, and force a
+        # fresh query so the next live chunk reflects the new prompt — no server/GUI restart.
+        idx, lt, seg = self._current_segment()
+        if idx != self._seg_idx:
+            self._seg_idx = idx
+            if not pf:                      # timeline owns prompt only when not externally controlled
+                self.prompt = seg["prompt"]
+                self._maybe_reanchor(self.prompt)   # restore clean stand if drifted (VLA_REANCHOR)
+            self._chunk = None
+            self._chunk_pos = 10**9
+            logger.info(
+                f"[vla_live] >>> segment {idx} @ step {self._global_t}: prompt={self.prompt!r} "
+                f"(settle={seg['settle_steps']}, bootstrap={seg['bootstrap_steps']})"
+            )
+
+        # Poll the control file so the user can switch motions at RUNTIME
+        # (e.g. `echo "kick" > $VLA_PROMPT_FILE`, or scripts/sonic_say.sh kick) — no restart.
+        if pf and self._global_t % 5 == 0:
+            try:
+                with open(pf) as fh:
+                    want = fh.read().strip()
+                if want and want != self.prompt:
+                    self.prompt = want
+                    self._chunk = None
+                    self._chunk_pos = 10**9
+                    self._maybe_reanchor(want)      # restore clean stand if drifted (VLA_REANCHOR)
+                    logger.info(f"[vla_live] >>> external prompt switch @ {self._global_t}: {want!r}")
+            except FileNotFoundError:
+                pass
+
+        # Re-anchor: snapshot a clean in-dist stand each step (gated by VLA_REANCHOR) so a later
+        # drifted switch to kick/jump/walk can write it back instead of freezing on OOD proprio.
+        self._capture_anchor()
+
+        # Phase-0 WBC-isolation trace (gated by VLA_DIAG_TRACE=<out.npz>): record per-step
+        # kinematics every control step — even during pure GT-token replay (no _query) — so the
+        # rollout can be scored OFFLINE (swing-foot peak height, root z/xy, joint trajectory)
+        # without a human watching the viewer. Answers "did the WBC actually produce the kick?".
+        tp = os.environ.get("VLA_DIAG_TRACE")
+        if tp:
+            try:
+                robot = self._scene["robot"]
+                i = self.env_index
+                if not hasattr(self, "_trace"):
+                    self._trace = {"t": [], "lt": [], "seg": [], "root": [], "joints": [], "bodyz": []}
+                    self._trace_names = [str(n) for n in getattr(robot, "body_names", [])]
+                    logger.info(f"[vla_live][TRACE] -> {tp}  body_names={self._trace_names}")
+                self._trace["t"].append(int(self._global_t))
+                self._trace["lt"].append(int(lt))
+                self._trace["seg"].append(int(idx))
+                self._trace["root"].append(robot.data.root_pos_w[i].detach().cpu().numpy().copy())
+                self._trace["joints"].append(robot.data.joint_pos[i].detach().cpu().numpy().copy())
+                self._trace["bodyz"].append(robot.data.body_pos_w[i, :, 2].detach().cpu().numpy().copy())
+                if self._global_t % 50 == 0:
+                    np.savez(tp,
+                             t=np.array(self._trace["t"]), lt=np.array(self._trace["lt"]),
+                             seg=np.array(self._trace["seg"]), root=np.array(self._trace["root"]),
+                             joints=np.array(self._trace["joints"]), bodyz=np.array(self._trace["bodyz"]),
+                             body_names=np.array(self._trace_names))
+            except Exception as exc:  # noqa: BLE001
+                logger.warning(f"[vla_live][TRACE] {exc!r}")
+
+        # DIAGNOSE the "flash to origin": log robot root every 50 steps regardless of segment, so
+        # walk segments (which don't query) are covered. A sudden jump to ~(0,0) = a teleport.
+        if self._global_t % 50 == 0:
+            try:
+                rp = self._scene["robot"].data.root_pos_w[self.env_index].detach().cpu().numpy()
+                logger.info(f"[vla_live] root@{self._global_t} seg{idx}({self.prompt[:9]}): "
+                            f"({rp[0]:.2f},{rp[1]:.2f},{rp[2]:.2f})")
+            except Exception:  # noqa: BLE001
+                pass
+
+        # Only query live once we're past this segment's settle+bootstrap windows; during those
+        # the decode hook injects neutral/dump tokens (no server needed). Refill when used up.
+        in_live = lt >= seg["settle_steps"] + (
+            seg["bootstrap_steps"] if seg["bootstrap"] is not None else 0
+        )
+        if in_live and not self._is_idle() and (self._chunk is None or self._chunk_pos >= self.action_horizon):
+            try:
+                self._query()
+            except Exception as exc:  # noqa: BLE001
+                logger.warning(f"[vla_live] query failed (keeping last chunk): {exc!r}")
+        return False  # never exit; user closes the viewer
